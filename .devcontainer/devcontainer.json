{
	"name": "IT-DOC1",
	"build": {
		"dockerfile": "Dockerfile",
	},
	"customizations": {
		"vscode": {
			"extensions": [
				"oracle.oracle-java",
				"vscjava.vscode-java-pack",
				"vmware.vscode-boot-dev-pack",
				"mhutchie.git-graph",
				"donjayamanne.githistory",
				"peakchen90.open-html-in-browser"
			]
		}
	},
	"postAttachCommand": "doas chgrp wheel /var/run/docker.sock",
    "remoteUser": "vscode",
    "mounts": [
        "source=${localEnv:HOME}${localEnv:USERPROFILE}/.m2,target=/workspaces/${localWorkspaceFolderBasename}/.m2,type=bind,consistency=cached",
        "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
    ]
}